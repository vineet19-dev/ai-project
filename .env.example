# .env.example
# ============================================================
# Environment Variables for LLM Evaluation Scripts
# ============================================================
# Copy this file to .env and fill in your actual API keys
# IMPORTANT: Never commit .env to version control!
#
# Add .env to .gitignore:
#   echo ".env" >> .gitignore
# ============================================================

# ────────────────────────────────────────────────────────────
# GOOGLE GEMINI API
# ────────────────────────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ────────────────────────────────────────────────────────────
# OPENAI API
# ────────────────────────────────────────────────────────────
# Get your API key at: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ────────────────────────────────────────────────────────────
# ANTHROPIC API (Claude)
# ────────────────────────────────────────────────────────────
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ────────────────────────────────────────────────────────────
# EVAL CONFIG (Optional)
# ────────────────────────────────────────────────────────────
# Max tokens per completion
MAX_TOKENS=4096

# Model temperature (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.7

# Number of evaluation runs per model
NUM_EVAL_RUNS=1

# Output directory for results
EVAL_OUTPUT_DIR=./eval_results
